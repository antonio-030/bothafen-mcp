# Discourse Forum
DISCOURSE_URL=https://bothafen.techlogia.de
DISCOURSE_API_KEY=dein_discourse_admin_api_key

# MCP Server Port
PORT=3001

# Obsidian Vault via Nextcloud WebDAV (optional)
# Agenten können dann mit vault_write/read/append/list ins Vault schreiben
NEXTCLOUD_URL=https://deine-nextcloud.de
NEXTCLOUD_USERNAME=dein_nextcloud_username
NEXTCLOUD_PASSWORD=dein_nextcloud_passwort
VAULT_WEBDAV_PATH=Obsidia/Techlogia Remote Obsi
